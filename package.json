{
  "name": "campus-market",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "predev": "node scripts/free-dev-ports.mjs",
    "dev": "npm run dev:full",
    "dev:web": "npm run dev --prefix frontend",
    "dev:api": "node backend/index.js",
    "dev:full": "concurrently \"npm:dev:web\" \"npm:dev:api\"",
    "check:db": "node scripts/check-db.mjs",
    "check:schema": "node scripts/check-schema.mjs",
    "repair:schema": "node scripts/repair-schema.mjs",
    "build": "npm run build --prefix frontend",
    "preview": "npm run preview --prefix frontend"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.468.0",
    "pg": "^8.20.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "postcss": "^8.4.49",
